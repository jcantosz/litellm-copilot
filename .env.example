# Example environment file for docker-compose
# Copy this to .env and fill in your values

# Option 1: Direct token (NOT RECOMMENDED for production)
# GITHUB_TOKEN=ghp_your_token_here

# Option 2: Command to retrieve token (e.g., from 1Password or keychain)
# COPILOT_PROXY_TOKEN_CMD=op read "op://Vault/Item/field"

# Option 3: Path to file containing token (for Docker secrets)
# GITHUB_TOKEN_FILE=./github_token.txt

# Optional: Custom port (default: 4000)
# PORT=4000
