# GitHub Personal Access Token with copilot scope
# Get one here: https://github.com/settings/tokens/new?scopes=copilot&description=LiteLLM%20Proxy
GITHUB_TOKEN=

# Optional: Command to retrieve token from secret manager (fallback if GITHUB_TOKEN not set)
# NOTE: Requires building a custom image with the CLI tools installed (e.g., op, security)
# COPILOT_PROXY_TOKEN_CMD=

# Optional: Custom port (default: 4000)
PORT=4000
